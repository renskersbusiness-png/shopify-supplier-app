# ─────────────────────────────────────────────
# Shopify Supplier App — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── Shopify ──────────────────────────────────
# Found in your Shopify custom app (Admin API)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# ── App ──────────────────────────────────────
PORT=3000

# Used to protect the dashboard — pick a strong random string
DASHBOARD_PASSWORD=change_me_to_something_strong

# Secret for session cookies — pick a long random string
SESSION_SECRET=change_me_to_a_long_random_secret_string

# ── Database ─────────────────────────────────
# Path to your SQLite database file
DB_PATH=./data/orders.db

# ── Environment ──────────────────────────────
NODE_ENV=development

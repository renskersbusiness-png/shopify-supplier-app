# ─────────────────────────────────────────────
# Shopify Supplier App — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── Shopify ──────────────────────────────────
# Your store's myshopify.com domain
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# From the Shopify Dev Dashboard → App → API credentials
# Used to obtain an Admin API access token at runtime (client credentials grant)
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# From Shopify Admin → Settings → Notifications → Webhooks → signing secret
# This is separate from the client secret above
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret_here

# ── App ──────────────────────────────────────
# Admin password — full access, sees all orders including pending/unpaid
ADMIN_PASSWORD=change_me_to_strong_admin_password

# Supplier password — only sees confirmed paid orders (status >= processing)
SUPPLIER_PASSWORD=change_me_to_strong_supplier_password

# Secret for signing session cookies — use a long random string
SESSION_SECRET=change_me_to_a_long_random_secret_string

# ── Environment ──────────────────────────────
NODE_ENV=development

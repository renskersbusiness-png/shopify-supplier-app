# ─────────────────────────────────────────────
# Shopify Supplier App — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── Shopify ──────────────────────────────────
# Your store's myshopify.com domain
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# From the Partners Dashboard → App → API credentials
# Client ID  = "API key"
# Client secret = "API secret key"
# These are used to obtain an Admin API access token at runtime
# AND to verify webhook HMAC signatures.
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# ── App ──────────────────────────────────────
PORT=3000

# Used to protect the dashboard — pick a strong random string
DASHBOARD_PASSWORD=change_me_to_something_strong

# Secret for session cookies — pick a long random string
SESSION_SECRET=change_me_to_a_long_random_secret_string

# ── Database ─────────────────────────────────
# Path to your SQLite database file
DB_PATH=./data/orders.db

# ── Environment ──────────────────────────────
NODE_ENV=development
